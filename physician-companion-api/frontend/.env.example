# API base — leave empty in dev to use Vite proxy (/api/v1 → localhost:3000)
VITE_API_BASE_URL=

# Dev bearer (matches backend NODE_ENV=development token format)
# After `npm run db:seed`, replace PHYSICIAN_ID with id from Prisma Studio
VITE_DEV_AUTH_TOKEN=dev:physician:dev-user:00000000-0000-4000-8000-000000000001:REPLACE_PHYSICIAN_ID
