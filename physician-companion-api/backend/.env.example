# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
API_PREFIX=/api/v1

# PostgreSQL (RDS in production — Multi-AZ, encrypted)
DATABASE_URL=postgresql://bridge:bridge_dev@localhost:5432/physician_companion?schema=public

# Redis (ElastiCache in production)
REDIS_URL=redis://localhost:6379

# Auth0 — physician mobile JWT + hospital SAML SSO
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.physician-companion.local
AUTH0_ISSUER=https://your-tenant.auth0.com/
AUTH0_JWKS_URI=https://your-tenant.auth0.com/.well-known/jwks.json
# Admin tokens use a separate audience/role claim
AUTH0_ADMIN_AUDIENCE=https://api.physician-companion.local/admin

# Epic FHIR R4 (SMART backend + bulk export — hospital-specific)
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_CLIENT_ID=
EPIC_CLIENT_SECRET=
# Intersystems IRIS SDK integration configured per deployment

# Expo Push (APNs + FCM)
EXPO_ACCESS_TOKEN=

# AWS (production)
AWS_REGION=us-east-1
AWS_KMS_KEY_ID=
S3_MEDITATION_BUCKET=
CLOUDFRONT_MEDITATION_DOMAIN=

# Feature flags
ENABLE_EPIC_SYNC=false
ENABLE_SCORE_CRON=false
